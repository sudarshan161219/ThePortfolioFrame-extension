{
  "manifest_version": 3,
  "name": "The Portfolio Frame",
  "version": "1.0.0",
  "description": "A minimalist, terminal-style screenshot beautifier.",
  "permissions": [
    "storage",
    "activeTab",
    "tabs",
    "unlimitedStorage",
    "debugger",
    "scripting",
    "contextMenus"
  ],
  "background": {
    "service_worker": "/src/background.ts",
    "type": "module"
  },
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Open The Portfolio Frame"
  },
  "web_accessible_resources": [
    {
      "resources": ["upload.html", "upload.js", "editor.html", "popup.html"],
      "matches": ["<all_urls>"]
    }
  ]
}
